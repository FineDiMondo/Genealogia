{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FAMILY",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "maxLength": 180,
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__FAMILY__[a-z0-9-]+__[a-z0-9-]+__[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "FAMILY"
      ]
    },
    "name": {
      "type": "string",
      "maxLength": 200
    },
    "slug": {
      "type": "string",
      "maxLength": 120,
      "pattern": "^[a-z0-9-]+$"
    },
    "date.sort": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "date.display": {
      "type": "string",
      "maxLength": 120
    },
    "place_id": {
      "type": "string"
    },
    "reliability": {
      "type": "string",
      "enum": [
        "DOCUMENTATO",
        "STAMPA",
        "ATTRIBUITO",
        "RICOSTRUITO"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "person_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "arms_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "media_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 4000
    }
  },
  "required": [
    "date.display",
    "date.sort",
    "id",
    "name",
    "place_id",
    "reliability",
    "slug",
    "source_ids",
    "type"
  ],
  "additionalProperties": true
}
