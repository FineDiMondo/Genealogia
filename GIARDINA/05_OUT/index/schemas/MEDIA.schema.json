{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MEDIA",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "maxLength": 220
    },
    "file_name": {
      "type": "string",
      "maxLength": 255
    },
    "ext": {
      "type": "string",
      "enum": [
        "jpg",
        "jpeg",
        "png",
        "pdf",
        "svg",
        "webp"
      ]
    },
    "mime": {
      "type": "string",
      "maxLength": 120
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "size_bytes": {
      "type": "integer"
    },
    "source_path": {
      "type": "string",
      "maxLength": 300
    },
    "curated_path": {
      "type": "string",
      "maxLength": 300
    },
    "credit": {
      "type": "string",
      "maxLength": 200
    },
    "copyright": {
      "type": "string",
      "maxLength": 300
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "required": [
    "created_at",
    "curated_path",
    "ext",
    "file_name",
    "id",
    "mime",
    "sha256",
    "size_bytes",
    "source_path"
  ],
  "additionalProperties": true
}
