---
interface Props {
  currentEnv?: string;
}

const { currentEnv = "PROD" } = Astro.props;
const path = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;
const menuItems = [
  { label: "01 HOME", href: `${baseUrl}` },
  { label: "02 DASHBOARD", href: `${baseUrl}gestionale/` },
  { label: "03 PERSONE", href: `${baseUrl}gestionale/search?domain=people` },
  { label: "04 FAMIGLIE", href: `${baseUrl}gestionale/search?domain=families` },
  { label: "05 REPORT", href: `${baseUrl}gestionale/reports` },
  { label: "06 JOBS", href: `${baseUrl}gestionale/batch-monitor` },
  { label: "07 ADMIN", href: `${baseUrl}gestionale/admin` },
  { label: "08 MONITOR", href: `${baseUrl}gestionale/monitoring` },
  { label: "09 HELP", href: `${baseUrl}gestionale/help` }
];
---

<div class="ispf-menu">
  {
    menuItems.map((item) => (
      <a href={item.href} class={path === item.href || (item.href !== "/" && path.startsWith(item.href.split("?")[0])) ? "active" : ""}>
        {item.label}
      </a>
    ))
  }
</div>
<div class="msg-line">ENV={currentEnv} | SISTEMA OPERATIVO | DIGITA COMMAND O USA PF</div>
