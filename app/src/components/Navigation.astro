---
interface Props {
  currentEnv?: string;
}

const { currentEnv = "PROD" } = Astro.props;
const path = Astro.url.pathname;
const menuItems = [
  { label: "HOME", href: "/" },
  { label: "PERSONE", href: "/gestionale/search?domain=people" },
  { label: "FAMIGLIE", href: "/gestionale/search?domain=families" },
  { label: "EVENTI", href: "/gestionale/reports?domain=events" },
  { label: "FONTI", href: "/gestionale/reports?domain=sources" },
  { label: "ARALDICA", href: "/gestionale/reports?domain=arms" },
  { label: "NOBILTA", href: "/gestionale/reports?domain=titles" },
  { label: "JOBS", href: "/gestionale/batch-monitor" },
  { label: "HELP", href: "/gestionale/help" }
];
---

<div class="ispf-menu">
  {
    menuItems.map((item) => (
      <a href={item.href} class={path === item.href ? "active" : ""}>
        {item.label}
      </a>
    ))
  }
</div>
<div class="ispf-message-line">ENV={currentEnv} | TYPE COMMAND OR PRESS PF KEYS</div>
