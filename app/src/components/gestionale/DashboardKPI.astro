---
import Panel from "../ui/Panel.astro";
---

<section class="kpi-grid">
  <Panel title="Versione Release" status="LIVE">
    <p id="kpi-version">loading...</p>
  </Panel>
  <Panel title="Persone Indicizzate" status="COUNT">
    <p id="kpi-people">-</p>
  </Panel>
  <Panel title="Ambiente" status="ENV">
    <p id="kpi-env">-</p>
  </Panel>
  <Panel title="Sample Persona" status="DATA">
    <p id="kpi-sample">-</p>
  </Panel>
</section>
<p id="kpi-error" style="color: var(--crt-red);"></p>

<style>
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-md);
  }

  .kpi-grid p {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    color: var(--crt-amber);
  }
</style>

