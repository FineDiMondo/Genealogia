---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<article class="card-ui">
  {title && <h3>{title}</h3>}
  <slot />
</article>

<style>
  .card-ui {
    border: 1px solid var(--crt-green);
    background: rgba(0, 51, 0, 0.35);
    padding: var(--space-md);
  }

  .card-ui h3 {
    margin-bottom: var(--space-sm);
  }
</style>

