---
import GestionalLayout from "../../layouts/GestionalLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Panel from "../../components/ui/Panel.astro";
---

<GestionalLayout title="Batch Monitor">
  <Navigation currentEnv="PROD" />
  <main class="section" style="padding: var(--space-xl);">
    <h1>Batch Monitor</h1>
    <Panel title="Orchestrator" status="RUNNER">
      <p>Comando principale: <code>bash jobs/run_job.sh</code></p>
      <p>Log: <code>logs/build_*.log</code></p>
    </Panel>
    <Panel title="GEDCOM Sync" status="SCHEDULER">
      <p>Comando test: <code>python gedcom_sync_orchestrator.py --run-once</code></p>
    </Panel>
  </main>
</GestionalLayout>

