---
import GestionalLayout from "../../layouts/GestionalLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Panel from "../../components/ui/Panel.astro";
const baseUrl = import.meta.env.BASE_URL;
---

<GestionalLayout title="PF1 Help">
  <Navigation currentEnv="PROD" />

  <main class="section" style="padding: var(--space-xl); display: grid; gap: var(--space-md);">
    <Panel title="ISPF GUIDE" status="PF1">
      <p>Retro layout 24x80 style. Usa COMMAND line o Function Keys.</p>
    </Panel>

    <Panel title="Function Keys" status="KEYS">
      <pre style="white-space: pre-wrap; color: var(--crt-white);">
PF1  HELP      apre questa guida
PF2  SPLIT     apre pannello corrente in nuova scheda
PF3  END       torna alla pagina precedente
PF4  RETURN    torna alla HOME
PF5  REFRESH   ricarica pagina
PF6  SORT      alterna parametro sort=asc/desc
PF7  UP        scroll su
PF8  DOWN      scroll giu
PF9  SWAP      alterna focus command line / pagina
PF10 LEFT      sezione precedente
PF11 RIGHT     sezione successiva
PF12 CANCEL    pulisce command line
      </pre>
    </Panel>

    <Panel title="Command Line" status="CMD">
      <pre style="white-space: pre-wrap; color: var(--crt-white);">
HOME
HELP
END
REFRESH
GO PERSONE
GO FAMIGLIE
GO EVENTI
GO FONTI
GO ARALDICA
GO NOBILTA
GO JOBS
FIND testo
SORT
      </pre>
    </Panel>

    <Panel title="Deploy and Cache" status="LINK">
      <p>
        Guida operativa per refresh cache PWA e verifica deploy:
        <a href={`${baseUrl}gestionale/deploy-cache`}>{baseUrl}gestionale/deploy-cache</a>
      </p>
    </Panel>
  </main>
</GestionalLayout>
