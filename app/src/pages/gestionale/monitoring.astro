---
import GestionalLayout from "../../layouts/GestionalLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Panel from "../../components/ui/Panel.astro";
---

<GestionalLayout title="Monitoring">
  <Navigation currentEnv="PROD" />
  <main class="section" style="padding: var(--space-xl);">
    <h1>System Monitoring</h1>
    <Panel title="Health Check" status="OK">
      <p>Verificare esistenza:</p>
      <ul>
        <li><code>/data/current/manifest.json</code></li>
        <li><code>/data/current/indexes/search_people.json</code></li>
        <li><code>/data/current/people/sample.json</code></li>
      </ul>
    </Panel>
  </main>
</GestionalLayout>

