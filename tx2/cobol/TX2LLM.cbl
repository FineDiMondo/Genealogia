       IDENTIFICATION DIVISION.
       PROGRAM-ID. TX2LLM.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
       COPY "TX2-LLM-IO.cpy".

       PROCEDURE DIVISION.
       MAIN.
           IF IN-TESTO-RICHIESTA = SPACES
              MOVE 12 TO OUT-COD-ESITO
              MOVE "TESTO RICHIESTA OBBLIGATORIO" TO OUT-MSG-ESITO
              MOVE 0 TO OUT-NUM-RISULTATI
              GOBACK
           END-IF

           CALL "LLM_STUB" USING IN-TESTO-RICHIESTA OUT-NUM-RISULTATI OUT-COD-ESITO
           IF OUT-COD-ESITO = 0
              MOVE "OK" TO OUT-MSG-ESITO
           ELSE
              MOVE "ERRORE LLM STUB" TO OUT-MSG-ESITO
           END-IF
           GOBACK.
       END PROGRAM TX2LLM.
